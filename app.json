{
  "expo": {
    "name": "Weeg",
    "slug": "weeg-mobile",
    "version": "1.0.0",
    "scheme": "weeg",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a6fe8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.weeg.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a6fe8"
      },
      "package": "com.weeg.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-secure-store",
      "expo-local-authentication"
    ]
  }
}
